DATABASE_URL = "sqlite:///./test.db"
SECRET_KEY = "your_secret_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_KEY=""

WHISPER_API = local #openai para transcrever usando o modelo do chatGPT
BACKEND_MODE = local #AUTO para rodar em nuvem ou local na falta de crédio; openai para usar os modelos do ChatGPT

# --- gerador_atas module ---
# HuggingFace token required by WhisperX speaker diarization
HF_KEY=""

LOCAL_MODEL="qwen2.5-coder:3b"
# --- Configuração de Perfomance da VRAM para o WhisperX ---
# Opções de modelo: "small", "base", "turbo", "large-v3", etc. ("small" gasta < 2GB)
WHISPER_MODEL_SIZE="small"
# Opções de compute_type: "int8" ou "float16". "int8" divide o consumo de memória pela metade
WHISPER_COMPUTE_TYPE="int8"
# Lote por vez. Default = 1 para menor consumo de memória em GPUs limitadas
WHISPER_BATCH_SIZE="1"
